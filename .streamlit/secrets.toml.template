# My Agent Much (MAM) シークレット設定テンプレート
# このファイルを secrets.toml にコピーして実際の値を設定してください

# ── 認証 ──
APP_PASSWORD = "your_password_here"  # 空文字列にすると認証スキップ

# ── API Keys（プロバイダ優先順: Gemini → OpenAI → Grok → Anthropic）──
# 複数設定すると自動フォールバック。1つだけでも動作します。

GEMINI_API_KEY = ""      # Google Gemini API キー（メイン推奨・無料枠あり）
OPENAI_API_KEY = ""      # OpenAI GPT-4o API キー（第1フォールバック）
GROK_API_KEY = ""        # xAI Grok API キー（第2フォールバック）
ANTHROPIC_API_KEY = ""   # Anthropic Claude API キー（最終フォールバック）
